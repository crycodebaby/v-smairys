# ─── Interner Zugang (Pflicht) ───────────────────────────────────────────────
# 4-stellige PIN für /intern/* (siehe AGENTS.md).
ADMIN_DASHBOARD_PIN=
# Optional: HMAC-Secret (>= 16 Zeichen). Leer = deterministisch aus PIN abgeleitet.
ADMIN_DASHBOARD_SECRET=

# ─── Site ────────────────────────────────────────────────────────────────────
# Öffentliche Basis-URL (für Canonicals, Sitemap, OG).
NEXT_PUBLIC_SITE_URL=https://smairys.de

# ─── Supabase (serverseitiges internes Dashboard) ────────────────────────────
# Projekt-URL; darf öffentlich sein, wird serverseitig genutzt.
NEXT_PUBLIC_SUPABASE_URL=
# Service Role Key: NUR serverseitig verwenden, niemals im Client.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Kontaktformular / Lead-Zustellung ───────────────────────────────────────
# Server-only (KEIN NEXT_PUBLIC_): Endpoint, an den /api/contact validierte
# Leads serverseitig weiterleitet. Fehlt diese Variable, antwortet die API mit
# einer sicheren Fehlermeldung und der Lead wird NICHT zugestellt.
FORMCARRY_ENDPOINT=https://formcarry.com/s/JOH5HI9XWVI

# ─── API Rate-Limit (optional, Defaults: 5 / 60000ms) ────────────────────────
API_RATE_LIMIT_MAX=5
API_RATE_LIMIT_WINDOW_MS=60000
